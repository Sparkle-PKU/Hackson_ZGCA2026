{
  "name": "life-year-report",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-with-db.mjs next dev",
    "dev:mobile": "node scripts/run-with-db.mjs next dev -H 0.0.0.0",
    "build": "node scripts/run-with-db.mjs next build",
    "start": "node scripts/run-with-db.mjs next start",
    "start:render": "node scripts/start-render.mjs",
    "lint": "eslint .",
    "prisma:generate": "node scripts/run-with-db.mjs prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:setup": "node scripts/setup-db.mjs",
    "seed": "node scripts/run-with-db.mjs tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "prisma": "^5.22.0",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
